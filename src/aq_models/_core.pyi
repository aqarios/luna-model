from typing import overload
from enum import Enum
from numpy.typing import NDArray

class Model: ...

class MatrixTranslator:
    @overload
    @staticmethod
    def to_model(qubo: NDArray): ...
    @overload
    @staticmethod
    def to_model(qubo: NDArray, name: str): ...

class Expression:
    def to_string(self, environment: Environment) -> str: ...

class Vtype(Enum):
    Real = ...
    Integer = ...
    Binary = ...
    Spin = ...

class Bounds:
    def __init__(self, lower: float, upper: float) -> None: ...

class VariableExistsException(Exception):
    def __str__(self) -> str: ...

class Environment:
    def __init__(self) -> None: ...

class Variable:
    @overload
    def __new__(
        cls, name: str, vtype: Vtype | None = ..., bounds: Bounds | None = ...
    ) -> Variable: ...
    @overload
    def __new__(
        cls,
        name: str,
        environment: Environment,
        vtype: Vtype | None = ...,
        bounds: Bounds | None = ...,
    ) -> Variable: ...

